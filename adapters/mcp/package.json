{
  "name": "stigmem-mcp",
  "version": "0.4.0",
  "description": "MCP server for Stigmem — exposes assert_fact, query_facts, resolve_contradiction, subscribe_scope",
  "type": "module",
  "bin": {
    "stigmem-mcp": "./dist/server.js"
  },
  "main": "./dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsx src/server.ts",
    "type-check": "tsc --noEmit",
    "test": "vitest run --exclude dist/**"
  },
  "license": "Apache-2.0",
  "dependencies": {
