    "@eidetic-labs/stigmem-ts": "workspace:*",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^4.1.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vite": "^6.3.0",
    "vitest": "^4.1.0"
  }
}
