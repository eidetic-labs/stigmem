{
  "spec_section": "§5.19–§5.20, §17.3",
  "title": "Garden-Tagged Facts — Wire Format Conformance",
  "description": "Validates POST /v1/facts and GET /v1/facts with garden_id parameter (§5.19, §5.20). Also validates garden ACL enforcement (§17.3): non-members receive 403 on both write and garden-filtered reads.",
  "note": "These vectors require an authed node with a pre-created garden. The test runner sets up the garden and the appropriate key before running each vector.",
  "vectors": [
    {
      "id": "garden-fact-write-201",
      "description": "POST /v1/facts with garden_id by a garden member returns 201 (§5.19)",
      "method": "POST",
      "path": "/v1/facts",
      "body": {
        "entity": "stigmem://testnode/project/atlas",
        "relation": "roadmap:status",
        "value": {"type": "string", "v": "in-flight"},
        "source": "stigmem://testnode/agent/admin",
        "confidence": 1.0,
        "scope": "team",
        "garden_id": "stigmem://testnode/garden/conf-garden"
      },
      "expected_status": 201,
      "expected_body_has_keys": ["id", "garden_id"],
      "requires_auth": "admin",
      "requires_garden": "conf-garden"
    },
    {
      "id": "garden-fact-write-scope-mismatch",
      "description": "POST /v1/facts with garden_id but wrong scope returns error (§17.3 scope invariant)",
      "method": "POST",
      "path": "/v1/facts",
      "body": {
        "entity": "stigmem://testnode/project/atlas",
        "relation": "roadmap:status",
        "value": {"type": "string", "v": "blocked"},
        "source": "stigmem://testnode/agent/admin",
        "confidence": 1.0,
        "scope": "company",
        "garden_id": "stigmem://testnode/garden/conf-garden"
      },
      "expected_status_in": [403, 422],
      "requires_auth": "admin",
      "requires_garden": "conf-garden"
    },
    {
      "id": "garden-fact-write-not-member-403",
      "description": "POST /v1/facts with garden_id by a non-member returns 403 (§17.3)",
      "method": "POST",
      "path": "/v1/facts",
      "body": {
        "entity": "stigmem://testnode/project/atlas",
        "relation": "roadmap:status",
        "value": {"type": "string", "v": "blocked"},
        "source": "stigmem://testnode/agent/outsider",
        "confidence": 1.0,
        "scope": "team",
        "garden_id": "stigmem://testnode/garden/conf-garden"
      },
      "expected_status": 403,
      "requires_auth": "outsider",
      "requires_garden": "conf-garden"
    },
    {
      "id": "garden-fact-query-member-200",
      "description": "GET /v1/facts?garden_id=... by a garden member returns 200 (§5.20)",
      "method": "GET",
      "path": "/v1/facts?garden_id=stigmem%3A%2F%2Ftestnode%2Fgarden%2Fconf-garden",
      "body": null,
      "expected_status": 200,
      "expected_body_has_keys": ["facts"],
      "requires_auth": "admin",
      "requires_garden": "conf-garden"
    },
    {
      "id": "garden-fact-query-non-member-403",
      "description": "GET /v1/facts?garden_id=... by a non-member returns 403 — not empty list (§5.20, §17.3)",
      "method": "GET",
      "path": "/v1/facts?garden_id=stigmem%3A%2F%2Ftestnode%2Fgarden%2Fconf-garden",
      "body": null,
      "expected_status": 403,
      "requires_auth": "outsider",
      "requires_garden": "conf-garden"
    }
  ]
}
