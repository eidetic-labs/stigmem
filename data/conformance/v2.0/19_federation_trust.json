{
  "spec_section": "§19",
  "title": "Federation Trust — Wire Format Conformance",
  "description": "Validates /.well-known/stigmem federation advertisement shape and federation endpoint auth requirements per §19.",
  "vectors": [
    {
      "id": "fed-wellknown-disabled-default",
      "description": "Default node (no federation config) — /.well-known/stigmem returns federation=disabled (§19.1)",
      "method": "GET",
      "path": "/.well-known/stigmem",
      "body": null,
      "expected_status": 200,
      "expected_body_contains": {
        "federation": "disabled"
      }
    },
    {
      "id": "fed-wellknown-core-fields-present",
      "description": "/.well-known/stigmem always exposes version, node_id, node_url, auth, federation regardless of federation state (§19.1, §3.2)",
      "method": "GET",
      "path": "/.well-known/stigmem",
      "body": null,
      "expected_status": 200,
      "expected_body_has_keys": ["version", "node_id", "node_url", "auth", "federation"]
    },
    {
      "id": "fed-wellknown-federation-field-is-string",
      "description": "federation field is a string enum, not an object (§19.1)",
      "method": "GET",
      "path": "/.well-known/stigmem",
      "body": null,
      "expected_status": 200,
      "expected_body_value_in": {
        "federation": ["disabled", "enabled"]
      }
    },
    {
      "id": "fed-peers-list-requires-federate-permission",
      "description": "GET /v1/federation/peers requires federate permission — 401/403 without credentials (§19.2)",
      "method": "GET",
      "path": "/v1/federation/peers",
      "body": null,
      "expected_status_in": [401, 403, 404],
      "requires_auth": true
    },
    {
      "id": "fed-facts-pull-requires-peer-jwt",
      "description": "GET /v1/federation/facts requires valid Ed25519-signed peer JWT (§19.3) — 401 without token",
      "method": "GET",
      "path": "/v1/federation/facts",
      "body": null,
      "expected_status_in": [401, 403, 404],
      "requires_auth": true
    },
    {
      "id": "fed-scope-violation-audit",
      "description": "Facts pushed outside allowed_scopes produce a 403 and audit entry (§19.4) — requires active peer setup",
      "method": "POST",
      "path": "/v1/federation/facts",
      "body": {
        "facts": [
          {
            "id": "00000000-0000-0000-0000-000000000001",
            "entity": "stigmem://peer/user/alice",
            "relation": "memory:role",
            "value": {"type": "string", "v": "engineer"},
            "source": "stigmem://peer-node",
            "timestamp": "2026-01-01T00:00:00Z",
            "hlc": "1735689600000.000",
            "confidence": 1.0,
            "scope": "private"
          }
        ]
      },
      "expected_status_in": [401, 403, 404],
      "requires_auth": true
    }
  ]
}
