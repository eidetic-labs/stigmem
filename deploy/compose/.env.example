# stigmem Compose recipe — environment template
# Copy to .env and fill in values before running docker compose.
# DO NOT commit .env to git.

# ── Node identity ────────────────────────────────────────────────────────────
# Public URL of this node; included in federation handshakes.
STIGMEM_NODE_URL=http://localhost:8765

# Port exposed on the host machine.
STIGMEM_PORT=8765

# ── Auth ─────────────────────────────────────────────────────────────────────
# Set true in production. When false, all callers are trusted.
STIGMEM_AUTH_REQUIRED=false

# OIDC bridge (requires STIGMEM_AUTH_REQUIRED=true)
STIGMEM_OIDC_ENABLED=false
STIGMEM_OIDC_ISSUER_URL=
STIGMEM_OIDC_AUDIENCE=
STIGMEM_OIDC_ALLOWED_DOMAINS=
STIGMEM_OIDC_TOKEN_TTL_HOURS=8

# ── Storage ──────────────────────────────────────────────────────────────────
# "sqlite" (default) or "libsql" (Turso embedded-replica)
STIGMEM_STORAGE_BACKEND=sqlite

# libSQL / Turso — only needed when STIGMEM_STORAGE_BACKEND=libsql
STIGMEM_LIBSQL_URL=
STIGMEM_LIBSQL_AUTH_TOKEN=

# ── Encryption at rest ───────────────────────────────────────────────────────
# "off" (default) or "on" (SQLCipher; requires key material below)
STIGMEM_AT_REST_ENCRYPTION=off
# Name of the env var that holds the passphrase (not the passphrase itself):
STIGMEM_AT_REST_KEY_PASSPHRASE_ENV=STIGMEM_DB_PASSPHRASE
# The actual passphrase — only read when AT_REST_ENCRYPTION=on:
STIGMEM_DB_PASSPHRASE=

# ── Federation ───────────────────────────────────────────────────────────────
STIGMEM_FEDERATION_ENABLED=false
STIGMEM_FEDERATION_PULL_INTERVAL_S=30
STIGMEM_FEDERATION_PUSH_ENABLED=false
# Ed25519 keypair (base64url). Leave empty to auto-generate on first start.
STIGMEM_FEDERATION_PUBKEY=
STIGMEM_FEDERATION_PRIVKEY=

# ── Trust & sanitizer ────────────────────────────────────────────────────────
STIGMEM_TRUST_MODE=relaxed
STIGMEM_SANITIZER_MODE=warn
STIGMEM_SOURCE_ATTESTATION_MODE=warn

# ── Decay ────────────────────────────────────────────────────────────────────
# 0 = disabled
STIGMEM_DECAY_TTL_SECONDS=0
STIGMEM_DECAY_MIN_CONFIDENCE=0.0

# ── Logging ──────────────────────────────────────────────────────────────────
STIGMEM_LOG_LEVEL=info

# ── Postgres profile (future) ────────────────────────────────────────────────
POSTGRES_DB=stigmem
POSTGRES_USER=stigmem
POSTGRES_PASSWORD=<CHANGE_ME>
