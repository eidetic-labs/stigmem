# Stigmem backend URL — used by the Next.js proxy; also forwarded to the client
NEXT_PUBLIC_STIGMEM_API_URL=http://localhost:8765

# OIDC provider configuration — mirrors STIGMEM_OIDC_ISSUER_URL / STIGMEM_OIDC_AUDIENCE
OIDC_ISSUER_URL=https://your-idp.example.com
OIDC_CLIENT_ID=your-client-id
# Leave empty for public clients (PKCE only); set for confidential clients
OIDC_CLIENT_SECRET=
# Full URL of this app's auth callback route
OIDC_REDIRECT_URI=http://localhost:3000/api/auth/callback

# 32+ byte random secret for iron-session cookie encryption
# Generate with: openssl rand -base64 32
SESSION_SECRET=replace-with-a-32-byte-random-secret
