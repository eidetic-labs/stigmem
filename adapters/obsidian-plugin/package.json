{
  "name": "stigmem-obsidian-plugin",
  "version": "0.1.0",
  "description": "Obsidian community plugin for stigmem — real-time vault ↔ stigmem memory reflection",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc --noEmit --skipLibCheck && node esbuild.config.mjs production",
    "test": "vitest run --exclude main.js",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "keywords": ["obsidian", "stigmem", "memory", "knowledge-graph"],
  "author": "Eidetic-Labs",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "builtin-modules": "^4.0.0",
    "esbuild": "^0.21.5",
    "obsidian": "latest",
    "tslib": "^2.6.3",
    "typescript": "^5.5.3",
    "vite": "^6.3.0",
    "vitest": "^4.1.0"
  }
}
