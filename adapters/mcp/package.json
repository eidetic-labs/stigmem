{
  "name": "stigmem-mcp",
  "version": "0.9.0-alpha.9",
  "description": "MCP server for Stigmem — exposes assert_fact, query_facts, recall, resolve_contradiction, subscribe_scope, and lint_scope",
  "type": "module",
  "bin": {
    "stigmem-mcp": "dist/server.js"
  },
  "main": "./dist/server.js",
  "types": "./dist/server.d.ts",
  "files": [
    "dist/server.js",
    "dist/server.js.map",
    "dist/server.d.ts",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/server.js",
    "start": "node dist/server.js",
    "dev": "tsx src/server.ts",
    "type-check": "tsc --noEmit",
    "test": "vitest run src/server.test.ts"
  },
  "license": "Apache-2.0",
  "author": "Eidetic Labs <oss@eidetic-labs.ai>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eidetic-labs/stigmem.git",
    "directory": "adapters/mcp"
  },
  "homepage": "https://github.com/eidetic-labs/stigmem/tree/main/features/mcp-adapter#readme",
  "bugs": {
    "url": "https://github.com/eidetic-labs/stigmem/issues"
  },
  "keywords": [
    "stigmem",
    "mcp",
    "model-context-protocol",
    "agents",
    "memory"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@eidetic-labs/stigmem-ts": "workspace:*",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^4.1.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vite": "^6.3.0",
    "vitest": "^4.1.0"
  }
}
