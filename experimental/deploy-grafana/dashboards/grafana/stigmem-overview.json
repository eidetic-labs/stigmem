{
  "__inputs": [],
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0"},
    {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"}
  ],
  "annotations": {"list": []},
  "description": "Stigmem node overview — fact throughput, recall latency, contradictions, audit events, subscriptions.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "id": 100,
      "title": "Fact Throughput",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "unit": "reqps"},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 1},
      "id": 1,
      "options": {"legend": {"calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
      "targets": [
        {
          "expr": "sum(rate(stigmem_fact_write_total[1m])) by (tenant)",
          "legendFormat": "writes · {{tenant}}"
        },
        {
          "expr": "sum(rate(stigmem_fact_read_total[1m])) by (tenant)",
          "legendFormat": "reads · {{tenant}}"
        }
      ],
      "title": "Fact writes & reads (req/s)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "red", "value": 1}]}, "unit": "short"},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 1},
      "id": 2,
      "options": {"colorMode": "background", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"]}, "textMode": "auto"},
      "targets": [
        {
          "expr": "sum(rate(stigmem_contradiction_total[5m])) by (tenant)",
          "legendFormat": "{{tenant}}"
        }
      ],
      "title": "Contradiction rate (per 5 m)",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 9},
      "id": 101,
      "title": "Recall Latency",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "unit": "s"},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 10},
      "id": 3,
      "options": {"legend": {"calcs": ["mean", "p95"], "displayMode": "table", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(stigmem_recall_ranker_duration_seconds_bucket[5m])) by (le, tenant))",
          "legendFormat": "p50 · {{tenant}}"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(stigmem_recall_ranker_duration_seconds_bucket[5m])) by (le, tenant))",
          "legendFormat": "p95 · {{tenant}}"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(stigmem_recall_ranker_duration_seconds_bucket[5m])) by (le, tenant))",
          "legendFormat": "p99 · {{tenant}}"
        }
      ],
      "title": "Recall ranker latency (p50/p95/p99)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "unit": "s"},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 10},
      "id": 4,
      "options": {"legend": {"calcs": ["mean", "p95"], "displayMode": "table", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(stigmem_request_latency_seconds_bucket[5m])) by (le, route))",
          "legendFormat": "p95 · {{route}}"
        }
      ],
      "title": "HTTP request latency p95 by route",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 18},
      "id": 102,
      "title": "Audit Events & Quota",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "unit": "reqps"},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 19},
      "id": 5,
      "options": {"legend": {"calcs": ["mean"], "displayMode": "table", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
      "targets": [
        {
          "expr": "sum(rate(stigmem_audit_event_total[1m])) by (event_type)",
          "legendFormat": "{{event_type}}"
        }
      ],
      "title": "Audit events by type (req/s)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "unit": "reqps"},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 19},
      "id": 6,
      "options": {"legend": {"calcs": ["mean"], "displayMode": "table", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
      "targets": [
        {
          "expr": "sum(rate(stigmem_quota_breach_total[1m])) by (tenant, dimension)",
          "legendFormat": "{{tenant}} · {{dimension}}"
        }
      ],
      "title": "Quota breaches (req/s)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 27},
      "id": 103,
      "title": "Subscriptions",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "unit": "short"},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 28},
      "id": 7,
      "options": {"legend": {"calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
      "targets": [
        {
          "expr": "stigmem_subscription_connections_active",
          "legendFormat": "{{tenant}}"
        }
      ],
      "title": "Active subscriptions",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "unit": "reqps"},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 28},
      "id": 8,
      "options": {"legend": {"calcs": ["mean"], "displayMode": "table", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
      "targets": [
        {
          "expr": "sum(rate(stigmem_subscription_event_total[1m])) by (delivery_type, status)",
          "legendFormat": "{{delivery_type}} · {{status}}"
        }
      ],
      "title": "Subscription delivery events (req/s)",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["stigmem", "overview"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "name": "DS_PROMETHEUS",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      }
    ]
  },
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "Stigmem — Overview",
  "uid": "stigmem-overview",
  "version": 1
}
